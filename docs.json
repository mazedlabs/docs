{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mazed",
  "colors": {
    "primary": "#0a7c4a",
    "light": "#4DC991",
    "dark": "#0a7c4a"
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/favicon.svg",
  "fonts": {
    "family": "Satoshi",
    "source": "/fonts/Satoshi-Variable.woff2",
    "format": "woff2",
    "weight": 400,
    "heading": {
      "family": "Satoshi",
      "source": "/fonts/Satoshi-Variable.woff2",
      "format": "woff2",
      "weight": 700
    }
  },
  "icons": {
    "library": "fontawesome"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://mazed.ai"
  },
  "thumbnails": {
    "background": "/images/thumbnail.png"
  },
  "navigation": {
    "pages": [
      {
        "group": "Getting started",
        "pages": [
          "index",
          "quickstart"
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://mazed.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get a demo",
      "href": "https://mazed.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://mazed.ai"
    }
  }
}
